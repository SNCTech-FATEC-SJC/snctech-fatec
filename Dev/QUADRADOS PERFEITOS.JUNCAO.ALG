Algoritmo "semnome"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 26/03/2026
Var
   // Seçăo de Declaraçőes das variáveis
   valor1,valor2,valor3:inteiro


Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("==================CALCULADORA==================")
   escreval("Vocę escolheu Sequęncia de Quadrados perfeitos!")
   escreval
   escreval("1.Calculo do quadrado perfeito.")
   escreval("2.Crie uma Sequęncia de Quadrados perfeitos")
   leia(valor1)
   limpatela
   se(valor1=1)entao
      escreval("==================CALCULADORA==================")
      escreval
      escreva("Qual número vocę deseja calcular: ")
      leia(valor1)

      limpatela
      se(valor1<0)entăo
         enquanto (valor1<0) faca
            escreval("==================CALCULADORA==================")
            escreval
            escreval("Insira um valor que năo seja negativo")
            leia(valor1)
            limpatela
         fimenquanto
      fimse

      valor2<-valor1*valor1
      se(valor2>0) ou (valor2=0)entao
         escreval("==================CALCULADORA==================")
         escreval
         escreval(valor1," ao quadrado é o quadrado perfeito de",valor2)
         escreval("Pois",valor1," ao quadrado é",valor2)
         escreval
         escreval("Sequęncia de Quadrados perfeitos até o",valor1," :")
         valor3<-1
         enquanto (valor3=valor1) ou (valor3<valor1)  faca
            escreval(valor3*valor3)
            valor3<-valor3+1
         fimenquanto
      fimse
   fimse

   se(valor1=2)entao
      escreval("==================CALCULADORA==================")
      escreval
      escreval("Até qual termo vocę que tenha a seguęncia:")
      leia(valor1)
      limpatela

      se(valor1<0)entăo
         enquanto (valor1<0) faca
            escreval("==================CALCULADORA==================")
            escreval
            escreval("Insira um valor que năo seja negativo")
            leia(valor1)
            limpatela
         fimenquanto
      fimse
      valor2<-1
      enquanto (valor2=valor1) ou (valor2<valor1)  faca
         escreval(valor2*valor2)
         valor2<-valor2+1
      fimenquanto
   fimse


Fimalgoritmo